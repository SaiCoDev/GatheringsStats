# Copy this file to `.env.local` for local Next.js development or `.dev.vars` for Wrangler local preview.
# NEVER commit either file.

GATHERINGS_API_KEY=your_api_key_here
GATHERINGS_API_BASE_URL=https://gatherings.franchise.minecraft-services.net/api/v2.0
GATHERINGS_LIVE_ENDPOINT=/experiences

# Website Supabase — stores snapshots, served to visitors
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Game Server Supabase — source data (player_metrics, market, etc.)
GAME_SUPABASE_URL=https://your-game-project.supabase.co
GAME_SUPABASE_SERVICE_ROLE_KEY=your_game_service_role_key_here

# Cron protection - set the same secret in Cloudflare Workers secrets
CRON_SECRET=your_random_secret_here
