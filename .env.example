# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

GATHERINGS_API_KEY=your_api_key_here
GATHERINGS_API_BASE_URL=https://gatherings.franchise.minecraft-services.net/api/v2.0
GATHERINGS_LIVE_ENDPOINT=/experiences

# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cron protection — set this in Vercel env vars too, must match vercel.json cron secret
CRON_SECRET=your_random_secret_here
